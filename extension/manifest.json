{
  "manifest_version": 3,
  "name": "VeriLens Forensics Analyzer",
  "version": "0.1.0",
  "description": "Right-click media to run IPCV deepfake analysis",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*", "https://ipcv-final.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "VeriLens Forensics"
  }
}
